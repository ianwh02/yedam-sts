# Yedam STS Pipeline Configuration
# Copy to .env and modify as needed

# ============================================================
# STT Server (WhisperLive)
# ============================================================
# Model repo + name (must be CTranslate2 format on HuggingFace)
# Turbo (~0.8GB):  deepdml/faster-whisper-large-v3-turbo-ct2
# Large (~3GB):    Systran/faster-whisper-large-v3
# Medium (~1.5GB): Systran/faster-whisper-medium
# Small (~0.5GB):  Systran/faster-whisper-small
WHISPER_MODEL_REPO=deepdml/faster-whisper-large-v3-turbo-ct2
WHISPER_MODEL_NAME=faster-whisper-large-v3-turbo
WHISPER_COMPUTE_TYPE=int8_float16
WHISPER_MAX_CLIENTS=10
WHISPER_BATCH_MAX_SIZE=8
WHISPER_OMP_NUM_THREADS=4

# ============================================================
# LLM Server (vLLM)
# ============================================================
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ
LLM_QUANTIZATION=awq_marlin
LLM_GPU_MEMORY_UTILIZATION=0.35
LLM_MAX_MODEL_LEN=1024
LLM_MAX_NUM_SEQS=8
LLM_ENABLE_PREFIX_CACHING=true

# ============================================================
# TTS Server (nano-qwen3tts-vllm)
# ============================================================
TTS_GPU_MEMORY_UTILIZATION=0.40
TTS_PORT=7860
TTS_TALKER_TEMPERATURE=0.9
TTS_PREDICTOR_TEMPERATURE=0.9

# Audio post-processing (applied to decoded audio before output)
# High-pass filter cutoff in Hz (removes DC offset / low-freq rumble). Set to 0 to disable.
TTS_HIGHPASS_HZ=80

# Voice clone: per-language reference audio (optional)
# Set language-specific ref audio for consistent voice/pacing per language.
# Falls back to REF_AUDIO_PATH if no language-specific one is set.
# Falls back to custom voice mode (ryan/sohee presets) if none are set.
#REF_AUDIO_PATH=/app/ref_audio/default.wav
#REF_TEXT=
#REF_AUDIO_PATH_EN=/app/ref_audio/en.wav
#REF_TEXT_EN=Hello, this is a reference sentence.
#REF_AUDIO_PATH_KO=/app/ref_audio/ko.wav
#REF_TEXT_KO=안녕하세요, 이것은 참조 문장입니다.

# ============================================================
# Orchestrator
# ============================================================
ORCHESTRATOR_PORT=8080
STT_WS_URL=ws://stt:9090
LLM_API_URL=http://llm:8000/v1
TTS_API_URL=http://tts:7860
LOG_LEVEL=INFO

# Pipeline defaults
DEFAULT_SOURCE_LANG=ko
DEFAULT_TARGET_LANG=en
DEFAULT_PROCESSOR=translation

# Session limits
MAX_CONCURRENT_SESSIONS=5

# Context settings
LLM_CONTEXT_WINDOW_SEGMENTS=5
LLM_SUMMARY_INTERVAL_SEGMENTS=10
STT_INITIAL_PROMPT_SEGMENTS=3

# TTS concurrency
TTS_MAX_CONCURRENT=5
TTS_STALE_THRESHOLD=2
TTS_STALE_MAX_AGE_SECONDS=10.0
TTS_MIN_WORDS_COMMA_SPLIT=8
TTS_MAX_WORDS_PER_CHUNK=20

# ============================================================
# CUDA MPS (Multi-Process Service)
# ============================================================
# Enables concurrent GPU kernel execution across STT/LLM/TTS.
# Must start MPS daemon on host first: sudo ./scripts/cuda-mps.sh start
# Linux/WSL2 only — env vars are harmless if MPS not running.
MPS_PIPE_DIR=/tmp/nvidia-mps
STT_MPS_THREAD_PCT=30
LLM_MPS_THREAD_PCT=50
TTS_MPS_THREAD_PCT=20

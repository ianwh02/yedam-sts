# STS Pipeline Configuration
# Copy to .env to override defaults from docker-compose.yml.
# Most settings have sensible defaults — only set what you need to change.
# VRAM budgets are auto-computed by ./scripts/start.sh — don't set them manually.

# ============================================================
# Domain customization — swap these files for a different domain
# ============================================================
LLM_SYSTEM_PROMPT_PATH=./orchestrator/config/llm_prompt_church.txt
LLM_GLOSSARIES_DIR=./orchestrator/config/glossaries
LLM_DEFAULT_GLOSSARY=nazarene
STT_INITIAL_PROMPT_VOCAB_PATH=./orchestrator/config/stt_vocab_church.txt
STT_EXTRA_FLUSH_MARKERS=아멘,할렐루야

# ============================================================
# Bible verse lookup (Supabase)
# ============================================================
#BIBLE_SUPABASE_URL=https://your-project.supabase.co
#BIBLE_SUPABASE_KEY=your-anon-key
#BIBLE_TRANSLATION=kjv

# ============================================================
# Models (change these to swap models)
# ============================================================
#LLM_MODEL=Qwen/Qwen3-4B-AWQ
#WHISPER_MODEL_REPO=deepdml/faster-whisper-large-v3-turbo-ct2

# ============================================================
# CUDA MPS thread allocation (must sum to ~100%)
# ============================================================
#STT_MPS_THREAD_PCT=30
#LLM_MPS_THREAD_PCT=25
#TTS_MPS_THREAD_PCT=45

# ============================================================
# Voice cloning (optional — leave unset for preset speakers)
# ============================================================
#REF_AUDIO_PATH_EN=/app/ref_audio/en.wav
#REF_TEXT_EN=The exact text spoken in the reference audio
#REF_AUDIO_PATH_KO=/app/ref_audio/ko.wav
#REF_TEXT_KO=참조 오디오에서 말한 정확한 텍스트

# ============================================================
# Session limits
# ============================================================
#MAX_CONCURRENT_SESSIONS=5
